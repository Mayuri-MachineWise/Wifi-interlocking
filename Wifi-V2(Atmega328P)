#include <hidboot.h>
#include <usbhub.h>
#include <SPI.h>
#include <SoftwareSerial.h>

USB Usb;
HIDBoot<USB_HID_PROTOCOL_KEYBOARD> HidKeyboard(&Usb);

// ---------------- SERIAL ----------------
SoftwareSerial espSerial(4, 7);   // RX, TX

// ---------------- PINS ----------------
#define RELAY_PIN 9
#define LED_RED   8
#define LED_BLUE  6
#define LED_GREEN 5

// ---------------- STATE ----------------
int relayState = 0;

String qrData = "";
String lastQR = "";

unsigned long prevSend = 0;

// ---------------- RELAY ----------------
void applyRelay(int state)
{
  relayState = state;

  if (relayState == 1)
  {
    digitalWrite(RELAY_PIN, HIGH);
    digitalWrite(LED_RED, HIGH);
  }
  else
  {
    digitalWrite(RELAY_PIN, LOW);
    digitalWrite(LED_RED, LOW);
  }
}

// ---------------- SEND TO ESP ----------------
void sendToESP(String data)
{
  espSerial.println(data);
}

// ---------------- QR SCANNER PARSER ----------------
class KbdRptParser : public KeyboardReportParser
{
  void OnKeyDown(uint8_t mod, uint8_t key)
  {
    char c = OemToAscii(mod, key);

    if (!c) return;

    if (c == '\r' || c == '\n')
    {
      if (qrData.length() > 0)
      {
        lastQR = qrData;

        sendToESP("QR:" + lastQR);

        digitalWrite(LED_BLUE, HIGH);
        delay(100);
        digitalWrite(LED_BLUE, LOW);
      }

      qrData = "";
    }
    else
    {
      qrData += c;
    }
  }
};

KbdRptParser Parser;

// ---------------- SETUP ----------------
void setup()
{
  espSerial.begin(9600);

  pinMode(RELAY_PIN, OUTPUT);
  pinMode(LED_RED, OUTPUT);
  pinMode(LED_BLUE, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);

  digitalWrite(LED_GREEN, HIGH);

  // Relay remains in default state after power-up
  digitalWrite(RELAY_PIN, LOW);
  digitalWrite(LED_RED, LOW);

  if (Usb.Init() == -1)
  {
    while (1);
  }

  HidKeyboard.SetReportParser(0, &Parser);
}

// ---------------- LOOP ----------------
void loop()
{
  Usb.Task();

  // ---------- RECEIVE COMMAND FROM ESP ----------
  while (espSerial.available())
  {
    String cmd = espSerial.readStringUntil('\n');
    cmd.trim();

    if (cmd == "UNLOCK")
    {
      applyRelay(0);
    }
    else if (cmd == "LOCK")
    {
      applyRelay(1);
    }
  }

  // ---------- RESEND LAST QR EVERY SECOND ----------
  if ((millis() - prevSend) > 1000)
  {
    prevSend = millis();

    if (lastQR.length() > 0)
    {
      sendToESP("QR:" + lastQR);
    }
  }
}
